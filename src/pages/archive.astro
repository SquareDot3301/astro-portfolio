---
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const url = new URL(Astro.request.url);
const currentPage = Number(url.searchParams.get("page")) || 1;

const res = await fetch(
  `https://richalguemei.fr/api/posts?page=${currentPage}`
);

if (!res.ok) throw new Error("Erreur API");

const { posts, totalPages } = await res.json();
---

<Layout title="Archives" index="index, follow">
  <Navbar />

  <main class="max-w-3xl mx-auto px-4 py-10 text-white">
    <h1 class="text-3xl font-bold my-8">Archives</h1>

    <div class="flex flex-col gap-6 my-5">
      {
        posts.map((post: any) => (
          <a href={`/blog/${post.slug}`} class="border-b pb-4">
            <h2 class="text-xl font-bold">{post.title}</h2>
            <p class="text-gray-400 text-sm">
              {new Date(post.created_at).toLocaleDateString()}
            </p>
          </a>
        ))
      }
    </div>

    <!-- pagination -->
    <div class="mt-10 flex justify-between">
      {
        currentPage > 1 && (
          <a href={`/archive?page=${currentPage - 1}`}>
            ← Précédent
          </a>
        )
      }

      {
        currentPage < totalPages && (
          <a href={`/archive?page=${currentPage + 1}`}>
            Suivant →
          </a>
        )
      }
    </div>
  </main>

  <Footer />
</Layout>