---
export const prerender = false; // SSR pour contenu dynamique

import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import "../../styles/MarkdownPostLayout.css";
import { marked } from "marked";

const { slug } = Astro.params;

let post;

try {
  // Appel à ton API pour récupérer le post par slug
  const baseUrl = import.meta.env.PROD
    ? "https://richalguemei.fr"
    : "http://localhost:4000";

  const res = await fetch(`https://richalguemei.fr/api/posts/${slug}`);
  if (!res.ok) {
    throw new Error("Article introuvable");
  }
  post = await res.json();
} catch (err) {
  throw new Error("Article introuvable");
}

const datePost = new Date(post.created_at);
const description = post.description || "";

const contentHtml = marked(post.content);
---

<Layout title={post.title} description={description}>
  <div class="min-h-screen flex flex-col">
    <Navbar />

    <main class="flex-1 flex flex-col items-center justify-start">
      <h1
        class="text-3xl lg:text-4xl xl:text-6xl font-creative text-center md:text-black md:text-shadow-bottom-white my-7"
      >
        {post.title}
      </h1>

      <p class="text-gray-400 text-xl italic text-center">
        {datePost.getDate()}/{datePost.getMonth() + 1}/{datePost.getFullYear()}
      </p>

      <div class="flex justify-center my-3 flex-wrap">
        {
          post.tags?.map((tag: string) => (
            <a
              href={`/tags/${encodeURIComponent(tag)}/1`}
              class="bg-pink text-black mx-1 text-sm px-3 py-1 rounded-full"
            >
              {tag}
            </a>
          ))
        }
      </div>

      <div
        class="border-2 test text-text text-lg xl:text-xl p-5 rounded-4xl mx-2 sm:mx-7 md:mx-10 xl:mx-72 my-10 break-words tracking-wide"
        set:html={contentHtml}
      />
    </main>

    <div class="h-20"><Footer /></div>
  </div>
</Layout>
