---
export const prerender = false;

import Navbar from "../components/Navbar.astro";
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";

// Page courante
const url = new URL(Astro.request.url);
const currentPage = Number(url.searchParams.get("page")) || 1;

// Appel API
const baseUrl = import.meta.env.PROD
  ? "https://richalguemei.fr"
  : "http://localhost:4000";
const res = await fetch(
  `https://richalguemei.fr/api/posts?page=${currentPage}`,
);

if (!res.ok) {
  throw new Error("Impossible de récupérer les articles");
}

const data = await res.json();

const posts = data.posts || [];
const totalPages = data.totalPages || 1;

const heroPost = posts[0] || null;
const secondaryPosts = posts.slice(1, 5) || [];

const description = `Retrouvez ici mes billets de blog. 
Que ce soit des petits poèmes, mes analyses parfois bancales, ou des articles plus développés, 
ne manquez pas votre chance de trouver la perle rare à travers mes écrits !`;
---

<Layout
  title="Mon Blog"
  description={description}
  url="/blog"
  index="index, follow"
>
  <div class="min-h-screen flex flex-col">
  <div class="h-20"><Navbar /></div>

    <main class="flex-1 flex items-center justify-center">
    <div class="w-full max-w-6xl px-4 py-10">

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start text-white">

    <!-- COLONNE GAUCHE -->
    <div class="flex flex-col gap-6">
      {
        secondaryPosts.slice(0, 2).map((post: any) => (
          <a
            href={`/blog/${post.slug}`}
            class="group border border-white rounded-xl p-4 hover:bg-pink transition"
          >
            <h2 class="text-lg font-bold mb-2 group-hover:underline">
              {post.title}
            </h2>
            <p class="text-gray-400 text-sm">
              {post.content?.slice(0, 80)}...
            </p>
          </a>
        ))
      }
    </div>

    <!-- HERO (CENTRE) -->
    <div>
      {
        heroPost && (
          <a href={`/blog/${heroPost.slug}`} class="group block">
            <div class="rounded-2xl overflow-hidden border border-white">
              <div class="p-8 bg-pink transition hover:bg-[#9c4fb6]">
                <h1 class="text-3xl lg:text-4xl xl:text-5xl font-bold mb-6 group-hover:underline">
                  {heroPost.title}
                </h1>

                <p class="text-gray-300 text-lg leading-relaxed">
                  {heroPost.content?.slice(0, 200)}...
                </p>
              </div>
            </div>
          </a>
        )
      }
    </div>

    <!-- COLONNE DROITE -->
    <div class="flex flex-col gap-6">
      {
        secondaryPosts.slice(2, 4).map((post: any) => (
          <a
            href={`/blog/${post.slug}`}
            class="group border border-white rounded-xl p-4 hover:bg-pink transition"
          >
            <h2 class="text-lg font-bold mb-2 group-hover:underline">
              {post.title}
            </h2>
          </a>
        ))
      }
    </div>

  </div>

  <!-- POSTS EN BAS -->
  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mt-12">
    {
      secondaryPosts.slice(4, 10).map((post: any) => (
        <a
          href={`/blog/${post.slug}`}
          class="group border border-white rounded-xl p-4 hover:bg-pink transition"
        >
          <h2 class="text-lg font-bold mb-2 group-hover:underline">
            {post.title}
          </h2>
        </a>
      ))
    }
  </div>

  <!-- ARCHIVE -->
  <div class="mt-16 text-center">
    <a
      href="/archive"
      class="text-lg text-white font-bold underline hover:text-pink transition"
    >
      Voir tous les articles →
    </a>
  </div>

</main>

    <div class="h-20"><Footer /></div>
  </div>
</Layout>
